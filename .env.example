# Claudio FM 配置文件
# 复制此文件为 .env 并填入真实的 Key

# ── AI 大模型（必填）──────────────────────────────────────────
# 获取地址：https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# ── 服务器端口（可选）─────────────────────────────────────────
PORT=8080
PORT_RETRY_LIMIT=10
NCM_PORT=3001
LOG_LEVEL=info

# ── 推荐探索比例（可选）───────────────────────────────────────
# 默认 0.25，表示智能队列约 75% 来自你的歌单、25% 来自外部推荐
# 可填 0-0.8；也可以在电台里说“保守一点”“多发现新歌”“只听我的歌单”临时调整
EXTERNAL_RECOMMEND_RATIO=0.25

# ── 网易云音乐 Cookie（可选，加了之后版权歌曲更多）──────────────
# 如何获取：
#   1. 浏览器登录 https://music.163.com
#   2. F12 → Network → 随便点一首歌 → 找到请求头里的 Cookie
#   3. 粘贴整条 Cookie 字符串到这里
NETEASE_COOKIE=

# ── QQ 音乐 Cookie（可选，用你的 QQ 会员听完整歌曲）────────────
# 如何获取：
#   1. 浏览器打开 https://y.qq.com 并登录
#   2. F12 → Network → 点击任意请求 → 复制请求头里的 Cookie
#   3. 粘贴整条 Cookie 字符串到这里（含 uin=xxx 等字段）
# 作用：点歌时网易云找不到/仅试听，自动用 QQ 会员兜底
QQ_MUSIC_COOKIE=
QQ_CIRCUIT_THRESHOLD=3
QQ_CIRCUIT_COOLDOWN_MS=600000
QQ_UNAVAILABLE_CACHE_MS=900000
QQ_COOKIE_HEALTH_THRESHOLD=3
# SET 面板的 QQ 音乐扫码刷新使用此 Python 命令；首次使用前安装 qqmusic-api-python
PYTHON=python

# ── 天气上下文（可选，用于 DJ 播报）────────────────────────────
# 推荐使用高德开放平台天气 API：https://lbs.amap.com
# AMAP_WEATHER_CITY 使用城市 adcode，北京为 110000
# 不配置 AMAP_WEATHER_KEY 时，天气功能自动跳过；如配置 OPENWEATHER_API_KEY，则作为兜底
AMAP_WEATHER_KEY=
AMAP_WEATHER_CITY=110000
OPENWEATHER_API_KEY=
WEATHER_CITY=Nanjing,CN
WEATHER_UNITS=metric
WEATHER_LANG=zh_cn

# ── DJ 播报音色（可选）────────────────────────────────
# 默认接近夜间电台男声：语速略慢、音高略低
TTS_VOICE=zh-CN-YunxiNeural
TTS_RATE=0.80
TTS_PITCH=-10Hz
TTS_VOLUME=+0%
